# Copy this to .env and fill in real values
# See DEPLOY.md for Cloudflare setup instructions

# ── Database ──────────────────────────────────────────────────
# Runtime: Supabase session-mode pooler (port 5432)
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.njxtlukkoswzrmhwczqj:[YOUR-PASSWORD]@aws-0-ca-central-1.pooler.supabase.com:5432/postgres

# Migrations only: Supabase direct connection (port 5432)
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.njxtlukkoswzrmhwczqj.supabase.co:5432/postgres

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string

# ── Local dev only (uncomment to use local Docker DB) ─────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/firstline
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/firstline
