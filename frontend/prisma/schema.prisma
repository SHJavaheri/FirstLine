generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountRole {
  CONSUMER
  PROFESSIONAL
  ADMIN
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum ProfileVisibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum NotificationType {
  FRIEND_REQUEST
  RATING_RECEIVED
  RECOMMENDATION_RECEIVED
}

model Account {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  role            AccountRole @default(CONSUMER)
  firstName       String?
  lastName        String?
  profilePhotoUrl String?
  bannerPhotoUrl  String?
  jobTitle        String?
  bio             String?
  locationCity    String?
  locationState   String?
  phone           String?
  isSuspended     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  professional    ProfessionalProfile?
  favorites       FavoriteProfessional[]
  ratings         Rating[]
  
  sentFriendRequests      FriendRequest[]  @relation("SentFriendRequests")
  receivedFriendRequests  FriendRequest[]  @relation("ReceivedFriendRequests")
  friendships             Friendship[]     @relation("UserFriendships")
  friendOf                Friendship[]     @relation("FriendFriendships")
  friendRequestRateLimit  FriendRequestRateLimit?
  
  allowFriendRequests     Boolean  @default(true)
  profileVisibility       ProfileVisibility @default(PUBLIC)
  personalRecommendations PersonalRecommendation[]
  notifications           Notification[]
  
  serviceInterests        String[] @default([])
  consultationPreference  String?
  budgetMin               Int?
  budgetMax               Int?
  distancePreference      Int?
  emailVerified           Boolean  @default(false)
  phoneVerified           Boolean  @default(false)
  identityVerified        Boolean  @default(false)
  notificationPreferences Json?
  activityLogs            ActivityLog[]

  @@index([createdAt])
}

model ProfessionalProfile {
  id                    String   @id @default(cuid())
  accountId             String   @unique
  account               Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  profession            String
  specializations       String[]
  hourlyRate            Int?
  yearsExperience       Int?
  location              String?
  firmName              String?
  firmAddress           String?
  firmWebsite           String?
  yearsAtCurrentFirm    Int?
  totalExperienceYears  Int?
  licenseNumber         String?
  licensingBody         String?
  licenseJurisdiction   String?
  pricingModel          String?
  pricingDetails        String?
  minRate               Int?
  maxRate               Int?
  acceptsNewClients     Boolean  @default(true)
  offersInPerson        Boolean  @default(true)
  offersRemote          Boolean  @default(true)
  verified              Boolean  @default(false)
  rating                Float    @default(0)
  description           String?
  education             String?
  certifications        String?
  professionalBio       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  favoritedBy           FavoriteProfessional[]
  ratings               Rating[]
  personalRecommendations PersonalRecommendation[]

  @@index([profession])
  @@index([verified])
}

model FavoriteProfessional {
  id                      String   @id @default(cuid())
  consumerId              String
  professionalProfileId   String
  createdAt               DateTime @default(now())

  consumer                Account              @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  professionalProfile     ProfessionalProfile  @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)

  @@unique([consumerId, professionalProfileId])
  @@index([consumerId])
}

model Rating {
  id                      String   @id @default(cuid())
  consumerId              String
  professionalProfileId   String
  rating                  Int
  comment                 String?
  professionalReply       String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  consumer                Account              @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  professionalProfile     ProfessionalProfile  @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)

  @@unique([consumerId, professionalProfileId])
  @@index([professionalProfileId])
  @@index([consumerId])
}

model FriendRequest {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender      Account  @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    Account  @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId])
  @@index([createdAt])
}

model Friendship {
  id          String   @id @default(cuid())
  userId      String
  friendId    String
  createdAt   DateTime @default(now())

  user        Account  @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend      Account  @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@index([createdAt])
}

model FriendRequestRateLimit {
  id              String   @id @default(cuid())
  accountId       String   @unique
  requestCount    Int      @default(0)
  windowStart     DateTime @default(now())
  
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([windowStart])
}

model PersonalRecommendation {
  id                      String   @id @default(cuid())
  consumerId              String
  professionalProfileId   String
  category                String
  specialty               String?
  note                    String?
  isFavorite              Boolean  @default(false)
  visibility              ProfileVisibility @default(PUBLIC)
  selectedTags            String[] @default([])
  wouldUseAgain           String?
  professionalReply       String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  consumer                Account              @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  professionalProfile     ProfessionalProfile  @relation(fields: [professionalProfileId], references: [id], onDelete: Cascade)

  @@unique([consumerId, professionalProfileId])
  @@index([consumerId])
  @@index([professionalProfileId])
  @@index([category])
}

model Notification {
  id            String   @id @default(cuid())
  recipientId   String
  type          NotificationType
  relatedId     String
  actorId       String?
  message       String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recipient     Account  @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead])
  @@index([createdAt])
}

model ActivityLog {
  id              String   @id @default(cuid())
  accountId       String
  activityType    String
  relatedId       String?
  metadata        Json?
  createdAt       DateTime @default(now())
  
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  @@index([accountId, createdAt])
  @@index([activityType])
}
